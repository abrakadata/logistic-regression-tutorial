# Ignore everything by default
/*

# Keep gitignore itself tracked
!/.gitignore
!/README.md
!/LICENSE
!/.github/
!/.github/workflows/
!/.github/workflows/**

# Keep only the tutorial folder tracked
!/Logistic Regression Tutorial/
!/Logistic Regression Tutorial/**

# Ignore Python cache in tracked tutorial files
Logistic Regression Tutorial/__pycache__/
Logistic Regression Tutorial/**/*.py[cod]
